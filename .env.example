# RocketRide local engine
ROCKETRIDE_URI=http://127.0.0.1:32911
ROCKETRIDE_APIKEY=your-rocketride-api-key-here

# LLM used by the agent (llm_openai node)
ROCKETRIDE_OPENAI_KEY=your-openai-api-key-here

# Linkup live web search/grounding (used via tool_http_request)
ROCKETRIDE_LINKUP_APIKEY=your-linkup-api-key-here
